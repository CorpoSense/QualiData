# Database
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# AI Provider Keys (add your own)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=

# App Settings
APP_NAME=MasterDataCleaner API
DEBUG=false
SECRET_KEY=your-secret-key-here

# Document Knowledge Base
DOC_STORAGE_PATH=/tmp/masterdatacleaner_docs
DOC_MAX_FILE_SIZE_MB=50
DOC_CLEANUP_TTL_SECONDS=3600

# Lago Billing (add your own)
LAGO_API_KEY=
LAGO_WEBHOOK_SECRET=
