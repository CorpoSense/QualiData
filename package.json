{
  "name": "master-data-cleaner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "backend": "cd backend && . .venv/bin/activate && uvicorn app.main:app --reload --port 8000",
    "test:backend": "cd backend && . .venv/bin/activate && pytest -v",
    "test:backend:coverage": "cd backend && . .venv/bin/activate && pytest --cov=app --cov-report=term-missing --cov-report=html",
    "test:e2e": "cypress run",
    "test:frontend": "vitest run",
    "test:frontend:coverage": "vitest run --coverage",
    "test:dev": "vitest test tests/*",
    "test": "vue-tsc --noEmit && vite build && pnpm test:frontend && pnpm test:backend",
    "check": "vue-tsc --noEmit && vite build && pnpm test:backend",
    "clean": "rm -rf ./dist",
    "clean:all": "rm -rf ./dist && rm -rf ./node_modules && rm -rf ./backend/.venv"
  },
  "dependencies": {
    "@sgratzl/chartjs-chart-boxplot": "^4.4.5",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "bootstrap-vue-next": "^0.43.8",
    "chart.js": "^4.5.1",
    "dayjs": "^1.11.21",
    "pinia": "^3.0.4",
    "vue": "^3.5.29",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/compiler-sfc": "^3.5.29",
    "@vue/test-utils": "^2.4.6",
    "cypress": "^13.0.0",
    "happy-dom": "^20.8.8",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^5.4.21",
    "vitest": "^0.34.6",
    "vue-tsc": "^3.2.5"
  }
}
