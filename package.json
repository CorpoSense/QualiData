    "buefy": "^3.0.4",
    "cross-env": "^10.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-chartjs": "^5.3.3",
    "vue-draggable-next": "^2.3.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vue-tsc": "^3.1.4"
  }
}
