{
  "name": "master-data-cleaner",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "cross-env NODE_ENV=production vite preview",
    "start": "cross-env NODE_ENV=production node --loader ts-node/esm --no-warnings ./src/server.ts",
    "clean": "rm -rf ./dist",
    "clean:all": "rm -rf ./dist && rm -rf ./node_modules"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@hono/vite-dev-server": "^0.24.1",
    "axios": "^1.13.2",
    "buefy": "^3.0.4",
    "cross-env": "^10.1.0",
    "hono": "^4.11.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-chartjs": "^5.3.3",
    "vue-draggable-next": "^2.3.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@vitejs/plugin-vue": "^6.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vue-tsc": "^3.1.4"
  }
}
